{
  "title": "RegisteredTools",
  "tools": [
    {
      "annotations": {
        "destructiveHint": false,
        "readOnlyHint": true
      },
      "description": "Compute drift findings: observed facts versus the known-good baseline.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "subject": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Restrict the scan to one subject.",
            "title": "Subject"
          }
        },
        "title": "DriftScanArgs",
        "type": "object"
      },
      "name": "drift_scan"
    },
    {
      "annotations": {
        "destructiveHint": false,
        "readOnlyHint": false
      },
      "description": "Trip the kill switch to halt all subsequent execution immediately (SEC-8). Restoring service is an out-of-band operator action.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "reason": {
            "description": "Why execution is being halted; recorded in the audit trail.",
            "maxLength": 500,
            "minLength": 1,
            "title": "Reason",
            "type": "string"
          }
        },
        "required": [
          "reason"
        ],
        "title": "EmergencyStopArgs",
        "type": "object"
      },
      "name": "emergency_stop"
    },
    {
      "annotations": {
        "destructiveHint": false,
        "readOnlyHint": true
      },
      "description": "Return the full recorded (bitemporal) history of facts for a subject.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "predicate": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Predicate"
          },
          "subject": {
            "minLength": 1,
            "title": "Subject",
            "type": "string"
          }
        },
        "required": [
          "subject"
        ],
        "title": "FactHistoryArgs",
        "type": "object"
      },
      "name": "fact_history"
    },
    {
      "annotations": {
        "destructiveHint": false,
        "readOnlyHint": false
      },
      "description": "Parse captured host telemetry into observed facts.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "collector": {
            "enum": [
              "osquery",
              "aide",
              "probe",
              "talos",
              "cis"
            ],
            "title": "Collector",
            "type": "string"
          },
          "predicate": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Predicate"
          },
          "raw": {
            "description": "Raw tool output captured by a T0 read.",
            "maxLength": 4194304,
            "title": "Raw",
            "type": "string"
          },
          "subject": {
            "minLength": 1,
            "title": "Subject",
            "type": "string"
          }
        },
        "required": [
          "collector",
          "subject",
          "raw"
        ],
        "title": "IngestArgs",
        "type": "object"
      },
      "name": "ingest_observation"
    },
    {
      "annotations": {
        "destructiveHint": false,
        "readOnlyHint": true
      },
      "description": "List active fleet-state facts; filter by subject and/or fact_type.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "fact_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Filter to observed/desired/drift/known_good.",
            "title": "Fact Type"
          },
          "subject": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Filter to one subject, e.g. host:axiom.",
            "title": "Subject"
          }
        },
        "title": "QueryFactsArgs",
        "type": "object"
      },
      "name": "query_facts"
    },
    {
      "annotations": {
        "destructiveHint": true,
        "readOnlyHint": false
      },
      "description": "Run a tier-gated actuation via an adapter (DRY_RUN, approve, execute).",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "minLength": 1,
            "title": "Action",
            "type": "string"
          },
          "adapter": {
            "enum": [
              "ansible",
              "opentofu",
              "runbook",
              "ssh",
              "talosctl"
            ],
            "title": "Adapter",
            "type": "string"
          },
          "approval_token": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Approval Token"
          },
          "dry_run": {
            "default": true,
            "title": "Dry Run",
            "type": "boolean"
          },
          "endpoints": {
            "items": {
              "type": "string"
            },
            "title": "Endpoints",
            "type": "array"
          },
          "health_client_side_only": {
            "default": false,
            "title": "Health Client Side Only",
            "type": "boolean"
          },
          "host": {
            "minLength": 1,
            "title": "Host",
            "type": "string"
          },
          "host_type": {
            "enum": [
              "ubuntu",
              "talos",
              "windows",
              "cloud"
            ],
            "title": "Host Type",
            "type": "string"
          },
          "nodes": {
            "items": {
              "type": "string"
            },
            "title": "Nodes",
            "type": "array"
          },
          "ssh_alias": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Ssh Alias"
          },
          "wipe_mode": {
            "anyOf": [
              {
                "enum": [
                  "system-disk",
                  "user-disks",
                  "all"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Wipe Mode"
          }
        },
        "required": [
          "adapter",
          "host",
          "host_type",
          "action"
        ],
        "title": "RunActionArgs",
        "type": "object"
      },
      "name": "run_action"
    }
  ]
}
